# Ajout de la structure messagerie au schéma Firebase

Ajouter après "library" dans la structure universities/$universityId:

"conversations": {
  "description": "Messagerie instantanée professionnelle (Module 10)",
  "type": "object",
  "structure": {
    "$conversationId": {
      "type": "object",
      "properties": {
        "participants": {
          "type": "array",
          "description": "UIDs des 2 participants [teacherId, studentId/parentId]",
          "example": ["teacher-abc123", "student-xyz789"]
        },
        "type": {
          "type": "enum",
          "values": ["teacher-student", "teacher-parent"],
          "description": "Type de conversation"
        },
        "context": {
          "type": "object",
          "properties": {
            "studentId": "ID de l'étudiant concerné",
            "studentName": "Nom complet de l'étudiant",
            "className": "Ex: L1 Informatique",
            "courseId": "Cours en commun (optionnel)",
            "parentId": "ID du parent (si type teacher-parent)",
            "parentName": "Nom du parent (si applicable)"
          }
        },
        "lastMessage": {
          "type": "object",
          "properties": {
            "text": "Aperçu du dernier message",
            "timestamp": "Timestamp en millisecondes",
            "senderId": "UID de l'expéditeur",
            "read": "Boolean - message lu ou non"
          }
        },
        "createdAt": "Timestamp création",
        "updatedAt": "Timestamp dernière activité"
      },
      "children": {
        "messages": {
          "$messageId": {
            "type": "object",
            "properties": {
              "senderId": "UID expéditeur",
              "senderName": "Nom complet expéditeur",
              "senderRole": "teacher | student | parent",
              "text": "Contenu du message",
              "timestamp": "Timestamp en ms",
              "read": "Boolean",
              "readAt": "Timestamp lecture (null si non lu)",
              "attachments": {
                "type": "array",
                "items": {
                  "name": "Nom fichier",
                  "url": "URL Firebase Storage",
                  "type": "MIME type",
                  "size": "Taille en octets"
                }
              }
            }
          }
        }
      }
    }
  }
}

Modifier teachers pour ajouter:
"classes": {
  "type": "array",
  "description": "Liste des IDs de classes enseignées",
  "example": ["class-l1-info", "class-l2-maths"]
}

Modifier users pour ajouter:
"childId": {
  "type": "string",
  "description": "Pour les parents: ID de l'enfant (profileId)",
  "nullable": true
}
